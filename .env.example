# WordPress OIDC Plugin - Environment Configuration Example
# Copy this file to .env and fill in your actual values
# Add .env to .gitignore to prevent committing secrets!

# Enable/disable OIDC authentication (1 or 0)
WP_OIDC_ENABLED=1

# Keycloak realm URL
# Example: https://keycloak.example.com/realms/wordpress
WP_OIDC_ISSUER_URL=https://keycloak.example.com/realms/wordpress

# OAuth 2.0 Client ID from Keycloak
WP_OIDC_CLIENT_ID=wordpress

# OAuth 2.0 Client Secret from Keycloak (KEEP SECURE!)
# Generate in Keycloak: Client → Credentials tab → Copy value
WP_OIDC_CLIENT_SECRET=your-client-secret-here

# Custom redirect URI (optional)
# Leave empty to auto-generate from WordPress URL
# Must be registered in Keycloak as valid redirect URI
WP_OIDC_REDIRECT_URI=https://example.com/wp-login.php?oidc_callback=1
